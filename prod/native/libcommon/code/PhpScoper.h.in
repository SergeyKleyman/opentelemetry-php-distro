#pragma once

#include <array>
#include <string_view>

namespace opentelemetry::php::scoper {

using namespace std::string_view_literals;

constexpr char toLowerAscii(char c) noexcept
{
	return (c >= 'A' && c <= 'Z') ? static_cast<char>(c - 'A' + 'a') : c;
}

template <size_t N>
constexpr std::array<char, N> toLowerAsciiArray(std::string_view input) noexcept
{
	std::array<char, N> output{};
	for (size_t i = 0; i + 1 < N; ++i)
	{
		output[i] = toLowerAscii(input[i]);
	}
	output[N - 1] = '\0';

	return output;
}

